project = Arcanoid
description = Arcanoid Game Tutorial

# outputs
outputformats = HTML
outputdir = ../build/docs/html
overwrite = true

# inputs
sourcedirs = ../qml ../docs .
headerdirs = ../qml ../docs .

# HTML settings
HTML.stylesheets = style.css
HTML.headerstyles = \
    "<link rel=\"stylesheet\" type=\"text/css\" href=\"style.css\">\n"
HTML.endheader = "</head>\n<body>\n"

# main page
indexpages = index

# images
imagedirs = images

